# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/project-sharing
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/project-sharing
MONGO_URI=mongodb://127.0.0.1:27017/project-sharing

# Secret used to sign JWT tokens - change this to a long random string
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the Express server listens on
PORT=5000
